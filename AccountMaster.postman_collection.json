          }
        },
        {
          "name": "Update Business Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/business", "host": ["{{BASE_URL}}"], "path": ["business"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"My Shop Pvt Ltd\",\n  \"ownerName\": \"Rahul Sharma\",\n  \"phone\": \"9876543210\",\n  \"email\": \"rahul@myshop.com\",\n  \"address\": \"123, MG Road, Mumbai, Maharashtra - 400001\"\n}"
            }
